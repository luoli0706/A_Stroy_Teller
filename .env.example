# ============================================================
# A Story Teller 环境配置示例
# 复制为 .env 并填入实际值
# ============================================================

# --- Provider 选择 (ollama | openai | anthropic) ---
LLM_PROVIDER=ollama
# 单独指定 Embedding Provider（空则跟随 LLM_PROVIDER；anthropic 时自动回退 ollama）
# EMBEDDING_PROVIDER=ollama

# --- Ollama (本地) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_PLANNER=qwen3.5:9b
OLLAMA_MODEL_ROLE=qwen3.5:9b
OLLAMA_MODEL_INTEGRATOR=qwen3.5:9b
OLLAMA_MODEL_QUALITY=qwen3.5:9b
OLLAMA_MODEL_EMBEDDING=nomic-embed-text-v2-moe

# --- OpenAI (可选) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_PLANNER=gpt-4o
# OPENAI_MODEL_ROLE=gpt-4o
# OPENAI_MODEL_INTEGRATOR=gpt-4o
# OPENAI_MODEL_QUALITY=gpt-4o
# OPENAI_MODEL_EMBEDDING=text-embedding-3-small

# --- Anthropic (可选) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_PLANNER=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_ROLE=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_INTEGRATOR=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_QUALITY=claude-sonnet-4-20250514

# --- 生成参数 ---
OLLAMA_TEMPERATURE=0.7
MAX_RETRY=1
LLM_REQUEST_RETRY=3

# --- RAG 控制 ---
RAG_ENABLED=true
RAG_TOP_K=4
RAG_CHROMA_DIR=.data/rag_chroma
RAG_COLLECTION_NAME=story_memory_slices

# --- UI ---
APP_LANG=zh
